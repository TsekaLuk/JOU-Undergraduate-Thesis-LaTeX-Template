\makeatletter
\newcommand{\JOUAppendixChapter}[2]{%
    \begingroup
        \let\JOUOriginalCTEXAddTocLine\CTEX@addtocline
        \renewcommand{\CTEX@addtocline}[2]{}%
        \chapter{#2}%
    \endgroup
    \addcontentsline{toc}{chapter}{\protect\JOUTocCenteredEntry{#1}}%
}
\makeatother

\newcommand{\JOUApplyBodyTocLayout}{%
    \renewcommand{\contentsname}{\JOUTocTitle}%
    \setcounter{tocdepth}{1}%
    \contentsmargin{0pt}%
    \titlecontents{chapter}[0em]{\songti\zihao{-4}}%
        {\thecontentslabel\hspace{0.5em}}{}%
        {\titlerule*[0.5pc]{.}\contentspage}%
    \titlecontents{section}[1.8em]{\songti\zihao{-4}}%
        {\thecontentslabel\hspace{0.45em}}{}%
        {\titlerule*[0.5pc]{.}\contentspage}%
    \titlecontents{subsection}[3.4em]{\songti\zihao{-4}}%
        {\thecontentslabel\hspace{0.4em}}{}%
        {\titlerule*[0.5pc]{.}\contentspage}%
}
