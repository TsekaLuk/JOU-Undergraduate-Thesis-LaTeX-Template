\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{jouexcellentabstract}[2026/03/08 JOU excellent thesis abstract helpers]

\RequirePackage{../../styles/joufonts}
\RequirePackage{etoolbox}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{graphicx}
\RequirePackage{caption}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{url}
\RequirePackage{makecell}
\RequirePackage{multirow}
\RequirePackage{multicol}
\RequirePackage{tabularx}
\RequirePackage{setspace}
\RequirePackage{indentfirst}
\RequirePackage[absolute,overlay]{textpos}

\geometry{
    a4paper,
    top=3cm,
    bottom=2cm,
    inner=1.7cm,
    outer=2cm,
    headheight=0.8cm,
    headsep=0.35cm,
    footskip=1.0cm
}

\setlength{\TPHorizModule}{1cm}
\setlength{\TPVertModule}{1cm}
\textblockorigin{0cm}{0cm}
\setstretch{1.25}
\setlength{\parindent}{2em}
\setlength{\columnsep}{2.02em}
\setlength{\multicolsep}{0.35\baselineskip}
\setlength{\tabcolsep}{4pt}
\setlength{\arrayrulewidth}{0.5pt}
\renewcommand{\arraystretch}{1.15}
\setlength{\emergencystretch}{2em}

\newcommand{\JOUExcellentTitleFont}{\fontsize{16pt}{20pt}\selectfont}
\newcommand{\JOUExcellentBodyFont}{\fontsize{9.5pt}{11.875pt}\selectfont}
\newcommand{\JOUExcellentHeaderFont}{\fontsize{10.5pt}{13.125pt}\selectfont}
\newcommand{\JOUExcellentSectionFont}{\fontsize{13pt}{16.25pt}\selectfont}
\newcommand{\JOUExcellentSubsectionFont}{\fontsize{11pt}{13.75pt}\selectfont}
\newcommand{\JOUExcellentReferenceFont}{\fontsize{9pt}{11.25pt}\selectfont}
\newcommand{\JOUExcellentBioFont}{\fontsize{7.5pt}{9.375pt}\selectfont}
\newcommand{\JOUExcellentAbstractInset}{1.5em}

\newcolumntype{L}[1]{>{\raggedright\arraybackslash}p{#1}}
\newcolumntype{C}[1]{>{\centering\arraybackslash}p{#1}}
\newcolumntype{R}[1]{>{\raggedleft\arraybackslash}p{#1}}

\newcommand{\JOUExcellentApplyPageStyle}{%
    \fancyhf{}
    \fancyhead[C]{%
        {\JOUExcellentHeaderFont\heiti
        江苏海洋大学\JOUSharedSchoolYear{}届本科优秀毕业实习与设计（论文）摘要}%
    }
    \fancyfoot[C]{%
        {\JOUExcellentHeaderFont\songti - \thepage -}%
    }
    \renewcommand{\headrulewidth}{0.4pt}
    \renewcommand{\footrulewidth}{0pt}
}

\fancypagestyle{jouexcellent}{\JOUExcellentApplyPageStyle}

\pagestyle{jouexcellent}
\fancypagestyle{plain}{\JOUExcellentApplyPageStyle}

\setcounter{secnumdepth}{3}
\renewcommand{\thesection}{\arabic{section}}
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}
\renewcommand{\thesubsubsection}{\thesubsection.\arabic{subsubsection}}

\titleformat{\section}[block]
    {\normalfont\bfseries\JOUExcellentSectionFont\heiti}
    {\thesection}
    {0.9em}
    {}
\titlespacing*{\section}{0pt}{0.5\baselineskip}{0.5\baselineskip}

\titleformat{\subsection}[block]
    {\normalfont\bfseries\JOUExcellentSubsectionFont\heiti}
    {\thesubsection}
    {0.8em}
    {}
\titlespacing*{\subsection}{0pt}{0pt}{0pt}

\titleformat{\subsubsection}[runin]
    {\normalfont\JOUExcellentBodyFont\kaishu}
    {\thesubsubsection}
    {0.8em}
    {}
    [\hspace{1em}]
\titlespacing*{\subsubsection}{0pt}{0pt}{0pt}

\DeclareCaptionFont{jouexcellentcaption}{\fontsize{9pt}{11.25pt}\selectfont\kaishu\bfseries}
\captionsetup{
    font=jouexcellentcaption,
    labelsep=space,
    skip=6pt
}
\captionsetup[table]{position=top}
\captionsetup[figure]{position=bottom}

\newcommand{\JOUExcellentInsetBlock}[1]{%
    \noindent\hspace*{\JOUExcellentAbstractInset}%
    \begin{minipage}{\dimexpr\textwidth-2\JOUExcellentAbstractInset\relax}
        #1
    \end{minipage}\par
}

\makeatletter
\renewenvironment{thebibliography}[1]
    {%
        \JOUExcellentReferenceFont\songti
        \list{\@biblabel{\@arabic\c@enumiv}}{%
            \settowidth\labelwidth{\@biblabel{#1}}%
            \leftmargin\labelwidth
            \advance\leftmargin\labelsep
            \setlength{\labelsep}{0.5em}%
            \setlength{\itemsep}{0pt}%
            \setlength{\parsep}{0pt}%
            \setlength{\topsep}{0pt}%
            \setlength{\partopsep}{0pt}%
            \setlength{\listparindent}{0pt}%
        }%
        \sloppy
        \clubpenalty4000
        \widowpenalty4000
        \sfcode`\.\@m
    }
    {%
        \def\@noitemerr{\@latex@warning{Empty `thebibliography' environment}}%
        \endlist
    }
\makeatother

\newcommand{\JOUExcellentFirstPageNote}{%
    \if\relax\detokenize\expandafter{\JOUSharedSupervisorIntroNote}\relax
    \else
        \begin{textblock*}{8.4cm}(1.85cm,25.25cm)
            {\JOUExcellentBioFont\songti \JOUSharedSupervisorIntroNote}
        \end{textblock*}%
    \fi
}
