\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{joufonts}[2026/03/07 JOU shared font setup]

% 严格字体检查选项
% 用法: \usepackage[strictfonts]{joufonts}
% 效果: 缺少商业字体时阻止编译
\newif\ifjou@strictfontcheck
\jou@strictfontcheckfalse
\DeclareOption{strictfonts}{\jou@strictfontchecktrue}
\DeclareOption*{\PackageWarning{joufonts}{Unknown option '\CurrentOption'}}
\ProcessOptions\relax

\RequirePackage{iftex}
\ifXeTeX\else
    \PackageError{joufonts}{This template requires XeLaTeX}{Please compile with XeLaTeX.}
\fi

\RequirePackage{fontspec}
\RequirePackage{xeCJK}

\defaultfontfeatures{Ligatures=TeX}

\newcommand{\JOUOpenSourceFontDir}{fonts/opensource}
\newcommand{\JOUProprietaryFontDir}{fonts/proprietary}

\IfFileExists{fonts/opensource/Tinos-Regular.ttf}{%
    \renewcommand{\JOUOpenSourceFontDir}{fonts/opensource}%
    \renewcommand{\JOUProprietaryFontDir}{fonts/proprietary}%
}{%
    \IfFileExists{../../fonts/opensource/Tinos-Regular.ttf}{%
        \renewcommand{\JOUOpenSourceFontDir}{../../fonts/opensource}%
        \renewcommand{\JOUProprietaryFontDir}{../../fonts/proprietary}%
    }{}
}

\newcommand{\JOUFontMode}{oss}

\newcommand{\jou@setupopenlatin}{%
    \setmainfont[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=Tinos-Regular.ttf,
        BoldFont=Tinos-Bold.ttf,
        ItalicFont=Tinos-Italic.ttf,
        BoldItalicFont=Tinos-BoldItalic.ttf
    ]{Tinos-Regular.ttf}%
    \setsansfont[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=NotoSansCJKsc-Regular.otf,
        BoldFont=NotoSansCJKsc-Bold.otf
    ]{NotoSansCJKsc-Regular.otf}%
    \setmonofont[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=CourierPrime-Regular.ttf,
        BoldFont=CourierPrime-Bold.ttf
    ]{CourierPrime-Regular.ttf}%
}

\newcommand{\jou@setupproprietarylatin}{%
    \renewcommand{\JOUFontMode}{licensed}%
    \setmainfont[
        Path=\JOUProprietaryFontDir/,
        UprightFont=TimesNewRoman-Regular.ttf,
        BoldFont=TimesNewRoman-Bold.ttf
    ]{TimesNewRoman-Regular.ttf}%
    \IfFileExists{\JOUProprietaryFontDir/Arial-Regular.ttf}{%
        \setsansfont[
            Path=\JOUProprietaryFontDir/,
            UprightFont=Arial-Regular.ttf,
            BoldFont=Arial-Bold.ttf
        ]{Arial-Regular.ttf}%
    }{%
        \setsansfont[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=NotoSansCJKsc-Regular.otf,
            BoldFont=NotoSansCJKsc-Bold.otf
        ]{NotoSansCJKsc-Regular.otf}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/CourierNew-Regular.ttf}{%
        \setmonofont[
            Path=\JOUProprietaryFontDir/,
            UprightFont=CourierNew-Regular.ttf,
            BoldFont=CourierNew-Bold.ttf
        ]{CourierNew-Regular.ttf}%
    }{%
        \setmonofont[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=CourierPrime-Regular.ttf,
            BoldFont=CourierPrime-Bold.ttf
        ]{CourierPrime-Regular.ttf}%
    }%
}

\newcommand{\jou@setupopensourcecjk}{%
    % 开源字体兜底方案（仅在系统无商业字体时使用）
    % 注意：开源字体与商业字体字宽可能有 2-5% 差异
    % 建议：确保系统安装了 SimSun/KaiTi/FangSong (Windows) 或 STSong/STKaiti/STFangsong (macOS)
    \setCJKmainfont[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=NotoSerifCJKsc-Regular.otf,
        BoldFont=NotoSerifCJKsc-Bold.otf
    ]{NotoSerifCJKsc-Regular.otf}%
    \setCJKsansfont[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=NotoSansCJKsc-Regular.otf,
        BoldFont=NotoSansCJKsc-Bold.otf
    ]{NotoSansCJKsc-Regular.otf}%
    \setCJKfamilyfont{zhsong}[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=NotoSerifCJKsc-Regular.otf,
        BoldFont=NotoSerifCJKsc-Bold.otf
    ]{NotoSerifCJKsc-Regular.otf}%
    \setCJKfamilyfont{zhhei}[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=NotoSansCJKsc-Regular.otf,
        BoldFont=NotoSansCJKsc-Bold.otf
    ]{NotoSansCJKsc-Regular.otf}%
    \setCJKfamilyfont{zhkai}[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=LXGWWenKaiGB-Regular.ttf,
        BoldFont=LXGWWenKaiGB-Medium.ttf
    ]{LXGWWenKaiGB-Regular.ttf}%
    \setCJKfamilyfont{zhfs}[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=FandolFang-Regular.otf
    ]{FandolFang-Regular.otf}%
    \newCJKfontfamily\JOUXiaobiaoSong[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=NotoSerifCJKsc-Black.otf
    ]{NotoSerifCJKsc-Black.otf}%
    \newCJKfontfamily\JOUXingkai[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=LXGWWenKaiGB-Medium.ttf
    ]{LXGWWenKaiGB-Medium.ttf}%
    \newCJKfontfamily\JOULishu[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=NotoSerifCJKsc-Black.otf
    ]{NotoSerifCJKsc-Black.otf}%
}

\newcommand{\jou@setupproprietarycjk}{%
    \renewcommand{\JOUFontMode}{licensed}%
    \IfFileExists{\JOUProprietaryFontDir/SimSun.ttf}{%
        \setCJKmainfont[
            Path=\JOUProprietaryFontDir/,
            UprightFont=SimSun.ttf
        ]{SimSun.ttf}%
    }{%
        \setCJKmainfont[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=NotoSerifCJKsc-Regular.otf,
            BoldFont=NotoSerifCJKsc-Bold.otf
        ]{NotoSerifCJKsc-Regular.otf}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/SimHei.ttf}{%
        \setCJKsansfont[
            Path=\JOUProprietaryFontDir/,
            UprightFont=SimHei.ttf
        ]{SimHei.ttf}%
        \setCJKfamilyfont{zhhei}[
            Path=\JOUProprietaryFontDir/,
            UprightFont=SimHei.ttf
        ]{SimHei.ttf}%
    }{%
        \setCJKsansfont[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=NotoSansCJKsc-Regular.otf,
            BoldFont=NotoSansCJKsc-Bold.otf
        ]{NotoSansCJKsc-Regular.otf}%
        \setCJKfamilyfont{zhhei}[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=NotoSansCJKsc-Regular.otf,
            BoldFont=NotoSansCJKsc-Bold.otf
        ]{NotoSansCJKsc-Regular.otf}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/SimSun.ttf}{%
        \setCJKfamilyfont{zhsong}[
            Path=\JOUProprietaryFontDir/,
            UprightFont=SimSun.ttf
        ]{SimSun.ttf}%
    }{%
        \setCJKfamilyfont{zhsong}[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=NotoSerifCJKsc-Regular.otf,
            BoldFont=NotoSerifCJKsc-Bold.otf
        ]{NotoSerifCJKsc-Regular.otf}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/KaiTi_GB2312.ttf}{%
        \setCJKfamilyfont{zhkai}[
            Path=\JOUProprietaryFontDir/,
            UprightFont=KaiTi_GB2312.ttf
        ]{KaiTi_GB2312.ttf}%
    }{%
        \setCJKfamilyfont{zhkai}[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=LXGWWenKaiGB-Regular.ttf,
            BoldFont=LXGWWenKaiGB-Medium.ttf
        ]{LXGWWenKaiGB-Regular.ttf}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/FangSong_GB2312.ttf}{%
        \setCJKfamilyfont{zhfs}[
            Path=\JOUProprietaryFontDir/,
            UprightFont=FangSong_GB2312.ttf
        ]{FangSong_GB2312.ttf}%
    }{%
        \setCJKfamilyfont{zhfs}[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=FandolFang-Regular.otf
        ]{FandolFang-Regular.otf}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/FangZhengXiaoBiaoSongJianTi.ttf}{%
        \newCJKfontfamily\JOUXiaobiaoSong[
            Path=\JOUProprietaryFontDir/,
            UprightFont=FangZhengXiaoBiaoSongJianTi.ttf
        ]{FangZhengXiaoBiaoSongJianTi.ttf}%
    }{%
        \newCJKfontfamily\JOUXiaobiaoSong[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=NotoSerifCJKsc-Black.otf
        ]{NotoSerifCJKsc-Black.otf}%
    }%
    \IfFileExists{\JOUProprietaryFontDir/STXingkai.ttf}{%
        \newCJKfontfamily\JOUXingkai[
            Path=\JOUProprietaryFontDir/,
            UprightFont=STXingkai.ttf
        ]{STXingkai.ttf}%
    }{%
        \newCJKfontfamily\JOUXingkai[
            Path=\JOUOpenSourceFontDir/,
            UprightFont=LXGWWenKaiGB-Medium.ttf
        ]{LXGWWenKaiGB-Medium.ttf}%
    }%
    \newCJKfontfamily\JOULishu[
        Path=\JOUOpenSourceFontDir/,
        UprightFont=NotoSerifCJKsc-Black.otf
    ]{NotoSerifCJKsc-Black.otf}%
}

% ============================================================================
% 字体加载策略：优先商业字体，确保毕业论文标准化
% ============================================================================
% 优先级：
% 1. fonts/proprietary/ 本地商业字体文件
% 2. 系统安装的商业字体（Windows/macOS/Linux 自动检测）
% 3. fonts/opensource/ 仓库开源字体（最后兜底）
% ============================================================================

% 检查仓库开源字体是否存在（兜底方案必须可用）
\IfFileExists{\JOUOpenSourceFontDir/Tinos-Regular.ttf}{}{%
    \PackageError{joufonts}{Missing vendored fonts under fonts/opensource}{Run python3 scripts/download_fonts.py first.}
}

% 拉丁字体加载逻辑
\IfFileExists{\JOUProprietaryFontDir/TimesNewRoman-Regular.ttf}{%
    % 优先级1: 本地 proprietary 文件
    \jou@setupproprietarylatin
}{%
    % 优先级2: 尝试系统字体
    \IfFontExistsTF{Times New Roman}{%
        \renewcommand{\JOUFontMode}{system-licensed}%
        \setmainfont{Times New Roman}%
        \IfFontExistsTF{Arial}{%
            \setsansfont{Arial}%
        }{%
            \setsansfont[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSansCJKsc-Regular.otf,BoldFont=NotoSansCJKsc-Bold.otf]{NotoSansCJKsc-Regular.otf}%
        }%
        \IfFontExistsTF{Courier New}{%
            \setmonofont{Courier New}%
        }{%
            \setmonofont[Path=\JOUOpenSourceFontDir/,UprightFont=CourierPrime-Regular.ttf,BoldFont=CourierPrime-Bold.ttf]{CourierPrime-Regular.ttf}%
        }%
    }{%
        % 优先级3: 使用仓库开源字体（兜底）
        \jou@setupopenlatin
    }%
}

% CJK 字体加载逻辑
\IfFileExists{\JOUProprietaryFontDir/SimSun.ttf}{%
    % 优先级1: 本地 proprietary 文件
    \jou@setupproprietarycjk
}{%
    % 优先级2: 尝试系统字体（跨平台检测）
    \newif\ifjou@systemcjkfound
    \jou@systemcjkfoundfalse
    % 检测 Windows 字体
    \IfFontExistsTF{SimSun}{%
        \jou@systemcjkfoundtrue
        \renewcommand{\JOUFontMode}{system-licensed}%
        \setCJKmainfont{SimSun}%
        \IfFontExistsTF{SimHei}{\setCJKsansfont{SimHei}\setCJKfamilyfont{zhhei}{SimHei}}{\setCJKsansfont[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSansCJKsc-Regular.otf]{NotoSansCJKsc-Regular.otf}\setCJKfamilyfont{zhhei}[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSansCJKsc-Regular.otf]{NotoSansCJKsc-Regular.otf}}%
        \setCJKfamilyfont{zhsong}{SimSun}%
        \IfFontExistsTF{KaiTi}{\setCJKfamilyfont{zhkai}{KaiTi}}{\setCJKfamilyfont{zhkai}[Path=\JOUOpenSourceFontDir/,UprightFont=LXGWWenKaiGB-Regular.ttf]{LXGWWenKaiGB-Regular.ttf}}%
        \IfFontExistsTF{FangSong}{\setCJKfamilyfont{zhfs}{FangSong}}{\setCJKfamilyfont{zhfs}[Path=\JOUOpenSourceFontDir/,UprightFont=FandolFang-Regular.otf]{FandolFang-Regular.otf}}%
        \IfFontExistsTF{FZXiaoBiaoSong-B05}{\newCJKfontfamily\JOUXiaobiaoSong{FZXiaoBiaoSong-B05}}{\newCJKfontfamily\JOUXiaobiaoSong[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSerifCJKsc-Black.otf]{NotoSerifCJKsc-Black.otf}}%
        \IfFontExistsTF{STXingkai}{\newCJKfontfamily\JOUXingkai{STXingkai}}{\newCJKfontfamily\JOUXingkai[Path=\JOUOpenSourceFontDir/,UprightFont=LXGWWenKaiGB-Medium.ttf]{LXGWWenKaiGB-Medium.ttf}}%
        \newCJKfontfamily\JOULishu[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSerifCJKsc-Black.otf]{NotoSerifCJKsc-Black.otf}%
    }{}%
    % 检测 macOS 字体
    \ifjou@systemcjkfound\else
        \IfFontExistsTF{STSong}{%
            \jou@systemcjkfoundtrue
            \renewcommand{\JOUFontMode}{system-licensed}%
            \setCJKmainfont{STSong}%
            \IfFontExistsTF{STHeiti}{\setCJKsansfont{STHeiti}\setCJKfamilyfont{zhhei}{STHeiti}}{\setCJKsansfont[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSansCJKsc-Regular.otf]{NotoSansCJKsc-Regular.otf}\setCJKfamilyfont{zhhei}[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSansCJKsc-Regular.otf]{NotoSansCJKsc-Regular.otf}}%
            \setCJKfamilyfont{zhsong}{STSong}%
            \IfFontExistsTF{STKaiti}{\setCJKfamilyfont{zhkai}{STKaiti}}{\setCJKfamilyfont{zhkai}[Path=\JOUOpenSourceFontDir/,UprightFont=LXGWWenKaiGB-Regular.ttf]{LXGWWenKaiGB-Regular.ttf}}%
            \IfFontExistsTF{STFangsong}{\setCJKfamilyfont{zhfs}{STFangsong}}{\setCJKfamilyfont{zhfs}[Path=\JOUOpenSourceFontDir/,UprightFont=FandolFang-Regular.otf]{FandolFang-Regular.otf}}%
            \IfFontExistsTF{FZXiaoBiaoSong-B05}{\newCJKfontfamily\JOUXiaobiaoSong{FZXiaoBiaoSong-B05}}{\newCJKfontfamily\JOUXiaobiaoSong[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSerifCJKsc-Black.otf]{NotoSerifCJKsc-Black.otf}}%
            \IfFontExistsTF{STXingkai}{\newCJKfontfamily\JOUXingkai{STXingkai}}{\newCJKfontfamily\JOUXingkai[Path=\JOUOpenSourceFontDir/,UprightFont=LXGWWenKaiGB-Medium.ttf]{LXGWWenKaiGB-Medium.ttf}}%
            \newCJKfontfamily\JOULishu[Path=\JOUOpenSourceFontDir/,UprightFont=NotoSerifCJKsc-Black.otf]{NotoSerifCJKsc-Black.otf}%
        }{}%
    \fi
    % 优先级3: 使用仓库开源字体（兜底）
    \ifjou@systemcjkfound\else
        \jou@setupopensourcecjk
    \fi
}

% 编译时字体模式检查和警告
\AtBeginDocument{%
    \typeout{}%
    \typeout{===============================================}%
    \typeout{JOU Font Mode: \JOUFontMode}%
    \typeout{===============================================}%
    \typeout{}%
    %
    \def\JOUOSSMode{oss}%
    \ifx\JOUFontMode\JOUOSSMode
        % 商业字体完全缺失 - 发出严重警告
        \typeout{}%
        \typeout{!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!}%
        \typeout{! 错误: 未检测到商业字体                  !}%
        \typeout{!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!}%
        \typeout{}%
        \typeout{毕业论文需要标准化，必须使用商业字体！}%
        \typeout{当前未找到任何商业字体（对齐度将降低至 80-85\%）}%
        \typeout{}%
        \typeout{解决方案:}%
        \typeout{}%
        \typeout{>>> 第一步：运行字体检测脚本}%
        \typeout{}%
        \typeout{    python3 scripts/check_fonts.py}%
        \typeout{}%
        \typeout{>>> 第二步：根据你的操作系统安装字体}%
        \typeout{}%
        \typeout{    Windows 用户:}%
        \typeout{    - 检查 C:\string\Windows\string\Fonts 是否有宋体、楷体、仿宋}%
        \typeout{    - 如缺失，安装 Microsoft Office (自带标准字体)}%
        \typeout{}%
        \typeout{    macOS 用户:}%
        \typeout{    - 打开「字体册」应用}%
        \typeout{    - 搜索 STSong, STKaiti, STFangsong}%
        \typeout{    - 如缺失，从系统安装盘恢复字体}%
        \typeout{}%
        \typeout{    Linux 用户:}%
        \typeout{    - Ubuntu/Debian: sudo apt install ttf-mscorefonts-installer}%
        \typeout{    - Arch Linux:    yay -S ttf-ms-fonts}%
        \typeout{    - 安装后运行:    fc-cache -fv}%
        \typeout{}%
        \typeout{>>> 第三步（可选）：手动下载字体}%
        \typeout{}%
        \typeout{    将以下字体文件放入 fonts/proprietary/:}%
        \typeout{    - SimSun.ttf (宋体)}%
        \typeout{    - SimHei.ttf (黑体)}%
        \typeout{    - KaiTi_GB2312.ttf (楷体)}%
        \typeout{    - FangSong_GB2312.ttf (仿宋)}%
        \typeout{    - TimesNewRoman-Regular.ttf}%
        \typeout{}%
        \typeout{!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!}%
        %
        % 严格模式：阻止编译
        \ifjou@strictfontcheck
            \typeout{! 严格字体检查已启用，编译终止          !}%
            \typeout{!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!}%
            \typeout{}%
            \PackageError{joufonts}{%
                Commercial fonts required but not found!\MessageBreak
                Strict font checking is enabled.\MessageBreak
                \MessageBreak
                Run: python3 scripts/check_fonts.py\MessageBreak
                See above for installation instructions.%
            }{%
                Install system fonts or place font files in fonts/proprietary/\MessageBreak
                to ensure proper alignment with official handbook.\MessageBreak
                \MessageBreak
                To disable strict checking (not recommended),\MessageBreak
                remove 'strictfonts' option from documentclass.%
            }%
        % 宽松模式：警告但继续
        \else
            \typeout{! 警告模式：继续使用开源字体（对齐度降低）!}%
            \typeout{! 提示：如需强制检查，添加 strictfonts 选项!}%
            \typeout{!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!}%
            \typeout{}%
        \fi
    \fi
}
