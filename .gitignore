*.pdf

# 例外：保留测试基线 PDF（如果需要）
# !docx/*.pdf
# !tests/baseline/*.pdf

# ==================================================
# Python
# ==================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints

# ==================================================
# 字体文件
# ==================================================
# 私有商业字体（用户本地覆盖，不纳入公共仓库）
fonts/proprietary/*
!fonts/proprietary/.gitkeep
!fonts/proprietary/README.md

# 开源字体下载缓存（可选，如果通过脚本自动下载）
# fonts/opensource/*.zip
# fonts/opensource/*.tar.gz

# ==================================================
